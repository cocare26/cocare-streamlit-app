ls.prediction_utils import predict_network_issue\n","from utils.notification_utils import send_notification\n","\n","print(\"✅ Modules imported successfully\")\n","\n","# =========================\n","# =========================\n","# LOAD NOTIFICATIONS\n","# =========================\n","NOTI_PATH = f\"{PROJECT_PATH}/utils/Notifications \"\n","\n","def load_notifications():\n","    try:\n","        internal_ar = pd.read_csv(f\"{NOTI_PATH}/ internal_notifications.csv\", encoding=\"utf-8-sig\")\n","    except Exception as e:\n","        print(\"❌ internal_ar error:\", e)\n","        internal_ar = pd.DataFrame()\n","\n","    try:\n","        internal_en = pd.read_csv(f\"{NOTI_PATH}/internal_notifications_en.csv\", encoding=\"utf-8-sig\")\n","    except Exception as e:\n","        print(\"❌ internal_en error:\", e)\n","        internal_en = pd.DataFrame()\n","\n","    try:\n","        external_ar = pd.read_csv(f\"{NOTI_PATH}/external_notifications.csv\", encoding=\"utf-8-sig\")\n","    except Exception as e:\n","        print(\"❌ external_ar error:\", e)\n","        external_ar = pd.DataFrame()\n","\n","    try:\n","        external_en = pd.read_csv(f\"{NOTI_PATH}/external_notifications_en.csv\", encoding=\"utf-8-sig\")\n","    except Exception as e:\n","        print(\"❌ external_en error:\", e)\n","        external_en = pd.DataFrame()\n","\n","    return internal_ar, internal_en, external_ar, external_en\n","\n","\n","INTERNAL_AR, INTERNAL_EN, EXTERNAL_AR, EXTERNAL_EN = load_notifications()\n","\n","print(\"✅ Notifications loaded\")\n","print(INTERNAL_AR.shape, INTERNAL_EN.shape, EXTERNAL_AR.shape, EXTERNAL_EN.shape)\n","\n","# =========================\n","# 2) Paths\n","# =========================\n","CHAT_LOG_PATH = f\"{PROJECT_PATH}/data/chat_logs.csv\"\n","\n","INTENT_AR_DIR = f\"{PROJECT_PATH}/Intent_Ara\"\n","INTENT_EN_DIR = f\"{PROJECT_PATH}/intent_Eng\"\n","\n","RESPONSE_AR_PATH = f\"{INTENT_AR_DIR}/intent_response_map_ar.csv\"\n","FOLLOWUP_AR_PATH = f\"{INTENT_AR_DIR}/intent_follow_up_map_ar.csv\"\n","\n","RESPONSE_EN_PATH = f\"{INTENT_EN_DIR}/intent_response_map_en.csv\"\n","FOLLOWUP_EN_PATH = f\"{INTENT_EN_DIR}/intent_follow_up_map_en.csv\"\n","\n","NOTIFICATION_DIR = glob.glob(f\"{UTILS_PATH}/Notifications*\")[0]\n","\n","\n","def find_file(folder, clean_name):\n","    for filename in os.listdir(folder):\n","        if filename.strip() == clean_name:\n","            return os.path.join(folder, filename)\n","    raise FileNotFoundError(f\"Cannot find {clean_name} inside {folder}\")\n","\n","\n","INTERNAL_AR_PATH = find_file(NOTIFICATION_DIR, \"internal_notifications.csv\")\n","INTERNAL_EN_PATH = find_file(NOTIFICATION_DIR, \"internal_notifications_en.csv\")\n","EXTERNAL_AR_PATH = find_file(NOTIFICATION_DIR, \"external_notifications.csv\")\n","EXTERNAL_EN_PATH = find_file(NOTIFICATION_DIR, \"external_notifications_en.csv\")\n","\n","\n","# =========================\n","# 3) Helpers\n","# =========================\n","def safe_int(value, default=0):\n","    try:\n","        if value is None or value == \"\" or pd.isna(value):\n","            return default\n","        return int(float(value))\n","    except Exception:\n","        return default\n","\n","\n","def safe_float(value, default=0.0):\n","    try:\n","        if value is None or value == \"\" or pd.isna(value):\n","            return default\n","        return float(value)\n","    except Exception:\n","        return default\n","\n","\n","def get_value(row, keys, default=None):\n","    for key in keys:\n","        if key in row and row.get(key) not in [\"\", None]:\n","            return row.get(key)\n","    return default\n","\n","\n","def load_csv(path):\n","    if not os.path.exists(path):\n","        raise FileNotFoundError(f\"Missing file: {path}\")\n","    df = pd.read_csv(path, encoding=\"utf-8-sig\").fillna(\"\")\n","    df.columns = [c.strip() for c in df.columns]\n","    return df\n","\n","\n","def normalize_output(result, default_label=\"unknown\"):\n","    if isinstance(result, tuple):\n","        label = result[0] if len(result) > 0 else default_label\n","        score = result[1] if len(result) > 1 else 1.0\n","        return str(label).strip().lower(), float(score)\n","\n","    if isinstance(result, dict):\n","        label = result.get(\"label\", result.get(\"intent\", result.get(\"sentiment\", default_label)))\n","        score = result.get(\"score\", result.get(\"confidence\", 1.0))\n","        return str(label).strip().lower(), float(score)\n","\n","    return str(result).strip().lower(), 1.0\n","\n","\n","def normalize_sentiment_label(label):\n","    s = str(label).strip().lower()\n","\n","    if s in [\"negative\", \"neg\", \"label_0\", \"0\", \"سلبي\"]:\n","        return \"negative\"\n","    if s in [\"positive\", \"pos\", \"label_2\", \"2\", \"ايجابي\", \"إيجابي\"]:\n","        return \"positive\"\n","    if s in [\"neutral\", \"neu\", \"label_1\", \"1\", \"محايد\"]:\n","        return \"neutral\"\n","\n","    return \"neutral\"\n","\n","\n","# =========================\n","# 4) Smart Prediction\n","# =========================\n","def safe_prediction(metrics, intent=None, sentiment=None):\n","    metrics = metrics or {}\n","\n","    # 1) Try real prediction model first\n","    try:\n","        pred = predict_network_issue(metrics)\n","        if pred is not None:\n","            pred = int(pred)\n","            if pred == 1:\n","                return 1\n","    except Exception as e:\n","        print(\"[PREDICTION WARNING]\", e)\n","\n","    # 2) Smart fallback if company metrics are missing / incomplete\n","    network_intents = [\n","        \"slow_internet\",\n","        \"no_signal\",\n","        \"network_status\",\n","        \"network_complaint\",\n","        \"technical_support\"\n","    ]\n","\n","    repeat_count = safe_int(metrics.get(\"repeat_count\"), safe_int(metrics.get(\"history_count\"), 0))\n","    area_issue_count = safe_int(metrics.get(\"area_issue_count\"), 0)\n","    estimated_minutes = safe_int(metrics.get(\"estimated_resolution_minutes\"), 0)\n","\n","    # Angry repeated network complaint\n","    if intent in network_intents and sentiment == \"negative\" and repeat_count >= 2:\n","        return 1\n","\n","    # Area-wide repeated issue\n","    if area_issue_count >= 5:\n","        return 1\n","\n","    # Known outage / maintenance needs time\n","    if estimated_minutes > 0 and intent in network_intents:\n","        return 1\n","\n","    return 0\n","\n","\n","# =========================\n","# 5) Intent Responses\n","# =========================\n","def load_intent_maps(lang):\n","    if lang == \"ar\":\n","        response_df = load_csv(RESPONSE_AR_PATH)\n","        followup_df = load_csv(FOLLOWUP_AR_PATH)\n","    else:\n","        response_df = load_csv(RESPONSE_EN_PATH)\n","        followup_df = load_csv(FOLLOWUP_EN_PATH)\n","\n","    response_map = dict(\n","        zip(\n","            response_df[\"intent\"].astype(str).str.strip().str.lower(),\n","            response_df[\"response\"].astype(str)\n","        )\n","    )\n","\n","    followup_map = dict(\n","        zip(\n","            followup_df[\"intent\"].astype(str).str.strip().str.lower(),\n","            followup_df[\"follow_up\"].astype(str)\n","        )\n","    )\n","\n","    return response_map, followup_map\n","\n","\n","def get_intent_response(lang, intent):\n","    response_map, followup_map = load_intent_maps(lang)\n","    intent = str(intent).strip().lower()\n","\n","    response = response_map.get(intent)\n","    followup = followup_map.get(intent)\n","\n","    if response is None:\n","        response = response_map.get(\"other\") or response_map.get(\"unknown\") or (\n","            \"تم استلام رسالتك، كيف يمكنني مساعدتك؟\" if lang == \"ar\"\n","            else \"Your message has been received. How can I help you?\"\n","        )\n","\n","    if followup is None:\n","        followup = followup_map.get(\"other\") or followup_map.get(\"unknown\") or (\n","            \"هل يمكنك تزويدي بتفاصيل إضافية؟\" if lang == \"ar\"\n","            else \"Could you provide more details?\"\n","        )\n","\n","    return response, followup\n","\n","\n","# =========================\n","# 6) Notification Data\n","# =========================\n","def load_notification_tables():\n","    return {\n","        \"internal_ar\": load_csv(INTERNAL_AR_PATH),\n","        \"internal_en\": load_csv(INTERNAL_EN_PATH),\n","        \"external_ar\": load_csv(EXTERNAL_AR_PATH),\n","        \"external_en\": load_csv(EXTERNAL_EN_PATH),\n","    }\n","\n","\n","def get_notification_row(df, issue_type):\n","    row = df[df[\"issue_type\"].astype(str).str.strip() == str(issue_type).strip()]\n","\n","    if row.empty:\n","        row = df[df[\"issue_type\"].astype(str).str.strip() == \"normal\"]\n","\n","    if row.empty:\n","        raise ValueError(\"Notification CSV must contain issue_type='normal'\")\n","\n","    return row.iloc[0].to_dict()\n","\n","\n","# =========================\n","# 7) Issue Detection\n","# =========================\n","def detect_issue_type(metrics, prediction):\n","    metrics = metrics or {}\n","\n","    if prediction != 1:\n","        return \"normal\"\n","\n","    if metrics.get(\"outage\") is True:\n","        return \"outage\"\n","\n","    if metrics.get(\"maintenance\") is True:\n","        return \"maintenance\"\n","\n","    latency = safe_float(metrics.get(\"latency\"), 0)\n","    packet_loss = safe_float(metrics.get(\"packet_loss\"), 0)\n","    signal_strength = safe_float(metrics.get(\"signal_strength\"), 0)\n","    congestion = safe_float(metrics.get(\"congestion\"), 0)\n","    jitter = safe_float(metrics.get(\"jitter\"), 0)\n","\n","    if latency >= 250:\n","        return \"high_latency\"\n","    if packet_loss >= 5:\n","        return \"packet_loss\"\n","    if signal_strength <= -100:\n","        return \"weak_signal\"\n","    if congestion >= 80:\n","        return \"network_congestion\"\n","    if jitter >= 50:\n","        return \"unstable_connection\"\n","\n","    return \"network_problem\"\n","\n","\n","# =========================\n","# 8) Build Customer Notification\n","# =========================\n","def build_customer_notification(issue_type, external_ar_row, external_en_row, metrics):\n","    start_time = metrics.get(\"outage_started_at\", datetime.now().strftime(\"%Y-%m-%d %H:%M\"))\n","    duration = safe_int(metrics.get(\"estimated_resolution_minutes\"), 30)\n","\n","    reason_ar = get_value(\n","        external_ar_row,\n","        [\"customer_notification_ar\", \"external_notification_ar\"],\n","        \"يوجد خلل في الشبكة ونعمل على معالجته.\"\n","    )\n","\n","    reason_en = get_value(\n","        external_en_row,\n","        [\"customer_notification_en\", \"external_notification_en\"],\n","        \"There is a network issue and we are working on resolving it.\"\n","    )\n","\n","    ar = (\n","        f\"نعتذر عن الإزعاج. {reason_ar} \"\n","        f\"نوع العطل: {issue_type}. \"\n","        f\"وقت العطل: {start_time}. \"\n","        f\"المدة المتوقعة للحل: حوالي {duration} دقيقة. \"\n","        f\"نشكركم على تفهمكم.\"\n","    )\n","\n","    en = (\n","        f\"We apologize for the inconvenience. {reason_en} \"\n","        f\"Issue type: {issue_type}. \"\n","        f\"Issue time: {start_time}. \"\n","        f\"Expected resolution time: about {duration} minutes. \"\n","        f\"Thank you for your understanding.\"\n","    )\n","\n","    return ar, en\n","\n","\n","# =========================\n","# 9) Notification / Rules Engine\n","# =========================\n","def notification_engine(intent, sentiment, prediction, metrics):\n","    metrics = metrics or {}\n","    tables = load_notification_tables()\n","\n","    issue_type = detect_issue_type(metrics, prediction)\n","    network_problem = issue_type != \"normal\"\n","\n","    internal_ar = get_notification_row(tables[\"internal_ar\"], issue_type)\n","    internal_en = get_notification_row(tables[\"internal_en\"], issue_type)\n","    external_ar = get_notification_row(tables[\"external_ar\"], issue_type)\n","    external_en = get_notification_row(tables[\"external_en\"], issue_type)\n","\n","    severity = str(\n","        get_value(internal_en, [\"severity\"], get_value(external_en, [\"severity\"], \"low\"))\n","    ).lower()\n","\n","    priority = safe_int(\n","        get_value(internal_en, [\"priority\"], get_value(internal_ar, [\"priority\"], 1)),\n","        1\n","    )\n","\n","    customer_resolved = metrics.get(\"customer_resolved\", True)\n","    employee_resolved = metrics.get(\"employee_resolved\", True)\n","    repeat_count = safe_int(metrics.get(\"repeat_count\"), safe_int(metrics.get(\"history_count\"), 0))\n","    area_issue_count = safe_int(metrics.get(\"area_issue_count\"), 0)\n","    estimated_minutes = safe_int(metrics.get(\"estimated_resolution_minutes\"), 0)\n","\n","    notification_type = \"none\"\n","    display_channel = \"none\"\n","    escalation = False\n","    reason = \"no_notification\"\n","\n","    external_message_ar = None\n","    external_message_en = None\n","\n","    customer_ar, customer_en = build_customer_notification(\n","        issue_type=issue_type,\n","        external_ar_row=external_ar,\n","        external_en_row=external_en,\n","        metrics=metrics\n","    )\n","\n","    # 1) External: angry customer + unresolved issue\n","    if sentiment == \"negative\" and customer_resolved is False:\n","        notification_type = \"external_noti\"\n","        display_channel = \"customer_app\"\n","        external_message_ar = customer_ar\n","        external_message_en = customer_en\n","        reason = \"angry_customer_unresolved\"\n","\n","    # 2) External: repeated network problem\n","    if network_problem and repeat_count >= 2 and notification_type == \"none\":\n","        notification_type = \"external_noti\"\n","        display_channel = \"customer_app\"\n","        external_message_ar = customer_ar\n","        external_message_en = customer_en\n","        reason = \"repeated_network_problem\"\n","\n","    # 3) Internal: real technical issue not solved or needs time\n","    if network_problem and (employee_resolved is False or estimated_minutes > 0):\n","        notification_type = \"internal_noti\"\n","        display_channel = \"company_dashboard\"\n","        reason = \"technical_issue_unresolved_or_time_needed\"\n","\n","    # 4) Escalation: area-wide repeated issue\n","    if network_problem and area_issue_count >= 5 and repeat_count >= 3:\n","        notification_type = \"internal_noti\"\n","        display_channel = \"company_dashboard\"\n","        escalation = True\n","        reason = \"area_wide_repeated_issue\"\n","\n","    return {\n","        \"issue_type\": issue_type,\n","        \"network_problem\": network_problem,\n","        \"notification_type\": notification_type,\n","        \"display_channel\": display_channel,\n","        \"escalation\": escalation,\n","        \"notification_reason\": reason,\n","        \"severity\": severity,\n","        \"priority\": priority,\n","        \"repeat_count\": repeat_count,\n","        \"area_issue_count\": area_issue_count,\n","        \"customer_resolved\": customer_resolved,\n","        \"employee_resolved\": employee_resolved,\n","        \"internal_message_ar\": get_value(internal_ar, [\"employee_notification_ar\", \"internal_notification_ar\"]),\n","        \"internal_message_en\": get_value(internal_en, [\"employee_notification_en\", \"internal_notification_en\"]),\n","        \"external_message_ar\": external_message_ar,\n","        \"external_message_en\": external_message_en,\n","        \"suggested_action_ar\": get_value(internal_ar, [\"suggested_action_ar\", \"suggested_action\"]),\n","        \"suggested_action_en\": get_value(internal_en, [\"suggested_action_en\", \"suggested_action\"]),\n","        \"outage_started_at\": metrics.get(\"outage_started_at\"),\n","        \"estimated_resolution_minutes\": metrics.get(\"estimated_resolution_minutes\"),\n","    }\n","\n","\n","# =========================\n","# 10) Logging\n","# =========================\n","def log_chat(user_message, result):\n","    os.makedirs(os.path.dirname(CHAT_LOG_PATH), exist_ok=True)\n","\n","    row = {\n","        \"timestamp\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n","        \"user_message\": user_message,\n","        \"language\": result.get(\"language\"),\n","        \"intent\": result.get(\"intent\"),\n","        \"intent_confidence\": result.get(\"intent_confidence\"),\n","        \"sentiment\": result.get(\"sentiment\"),\n","        \"sentiment_score\": result.get(\"sentiment_score\"),\n","        \"prediction\": result.get(\"prediction\"),\n","        \"issue_type\": result.get(\"issue_type\"),\n","        \"network_problem\": result.get(\"network_problem\"),\n","        \"notification_type\": result.get(\"notification_type\"),\n","        \"display_channel\": result.get(\"display_channel\"),\n","        \"escalation\": result.get(\"escalation\"),\n","        \"notification_reason\": result.get(\"notification_reason\"),\n","        \"response\": result.get(\"response\"),\n","        \"followup_response\": result.get(\"followup_response\"),\n","    }\n","\n","    try:\n","        old = pd.read_csv(CHAT_LOG_PATH, encoding=\"utf-8-sig\")\n","        logs = pd.concat([old, pd.DataFrame([row])], ignore_index=True)\n","    except Exception:\n","        logs = pd.DataFrame([row])\n","\n","    logs.to_csv(CHAT_LOG_PATH, index=False, encoding=\"utf-8-sig\")\n","\n","\n","# =========================\n","# 11) Main Process\n","# =========================\n","def process_message(user_message, metrics=None):\n","    metrics = metrics or {}\n","\n","    lang = detect_language(user_message)\n","\n","    intent_raw = predict_intent(user_message, lang)\n","    intent, intent_confidence = normalize_output(intent_raw, \"unknown\")\n","\n","    sentiment_raw = predict_sentiment(user_message, lang)\n","    sentiment, sentiment_score = normalize_output(sentiment_raw, \"neutral\")\n","    sentiment = normalize_sentiment_label(sentiment)\n","\n","    prediction = safe_prediction(\n","        metrics=metrics,\n","        intent=intent,\n","        sentiment=sentiment\n","    )\n","\n","    response, followup_response = get_intent_response(lang, intent)\n","\n","    notification_decision = notification_engine(\n","        intent=intent,\n","        sentiment=sentiment,\n","        prediction=prediction,\n","        metrics=metrics\n","    )\n","\n","    result = {\n","        \"language\": lang,\n","        \"intent\": intent,\n","        \"intent_confidence\": intent_confidence,\n","        \"sentiment\": sentiment,\n","        \"sentiment_score\": sentiment_score,\n","        \"prediction\": prediction,\n","        \"response\": response,\n","        \"followup_response\": followup_response,\n","        **notification_decision,\n","    }\n","\n","    if result[\"notification_type\"] != \"none\":\n","        send_notification(result[\"notification_type\"], result)\n","\n","    log_chat(user_message, result)\n","\n","    return result\n","\n","\n","print(\"✅ CoCare FINAL UPDATED Engine Loaded Successfully\")"]},{"cell_type":"code","execution_count":5,"metadata":{"id":"jwjavX-7s8Ds","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778085391718,"user_tz":-180,"elapsed":46,"user":{"displayName":"Co Care","userId":"16668277648287571901"}},"outputId":"12712d45-4fc0-4887-affe-f964dc0f3e21"},"outputs":[{"output_type":"execute_result","data":{"text/plain":["<module 'utils.intent_utils' from '/content/drive/MyDrive/CoCare/utils/intent_utils.py'>"]},"metadata":{},"execution_count":5}],"source":["import utils.intent_utils as intent_utils\n","import importlib\n","\n","importlib.reload(intent_utils)"]},{"cell_type":"code","source":["import os\n","\n","if os.path.exists(CHAT_LOG_PATH):\n","    os.remove(CHAT_LOG_PATH)\n","\n","print(\"✅ chat logs cleared\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"XaVWFnnovAGd","executionInfo":{"status":"ok","timestamp":1778085391722,"user_tz":-180,"elapsed":3,"user":{"displayName":"Co Care","userId":"16668277648287571901"}},"outputId":"0b7fa507-f12c-4f60-fbaf-b9b6a17a93df"},"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ chat logs cleared\n"]}]},{"cell_type":"code","execution_count":7,"metadata":{"id":"3Q0_szgxwzJs","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778085391804,"user_tz":-180,"elapsed":81,"user":{"displayName":"Co Care","userId":"16668277648287571901"}},"outputId":"3ee04eb1-9751-4314-e8aa-02d440f97ad6"},"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Notifications loaded\n","INTERNAL_AR: (10, 8)\n","INTERNAL_EN: (10, 6)\n","EXTERNAL_AR: (10, 6)\n","EXTERNAL_EN: (10, 5)\n","✅ ENGINE READY - FINAL FIXED\n"]}],"source":["# =========================\n","# CoCare FULL ENGINE CLEAN - FINAL FIXED\n","# =========================\n","\n","from datetime import datetime\n","import os\n","import sys\n","import types\n","import importlib\n","import pandas as pd\n","\n","# =========================\n","# Setup\n","# =========================\n","PROJECT_PATH = \"/content/drive/MyDrive/CoCare\"\n","UTILS_PATH = f\"{PROJECT_PATH}/utils\"\n","\n","sys.path.insert(0, PROJECT_PATH)\n","sys.path.insert(0, UTILS_PATH)\n","os.chdir(PROJECT_PATH)\n","\n","utils_pkg = types.ModuleType(\"utils\")\n","utils_pkg.__path__ = [UTILS_PATH]\n","sys.modules[\"utils\"] = utils_pkg\n","importlib.invalidate_caches()\n","\n","from utils.language_utils import detect_language\n","from utils.intent_utils import predict_intent\n","from utils.sentiment_utils import predict_sentiment\n","\n","# =========================\n","# Paths\n","# =========================\n","CHAT_LOG_PATH = f\"{PROJECT_PATH}/data/chat_logs.csv\"\n","NOTI_PATH = f\"{PROJECT_PATH}/utils/Notifications \"   # مهم: في مسافة بالنهاية\n","\n","# =========================\n","# Reset logs for testing\n","# =========================\n","def clear_chat_logs():\n","    if os.path.exists(CHAT_LOG_PATH):\n","        os.remove(CHAT_LOG_PATH)\n","    print(\"✅ chat logs cleared\")\n","\n","# =========================\n","# Helpers\n","# =========================\n","def safe_int(value, default=0):\n","    try:\n","        if value == \"\" or pd.isna(value):\n","            return default\n","        return int(float(value))\n","    except:\n","        return default\n","\n","\n","def normalize_model_output(result, default=\"neutral\"):\n","    try:\n","        if isinstance(result, tuple):\n","            if len(result) == 2:\n","                return result[0], result[1]\n","            return result[0], 1.0\n","\n","        if isinstance(result, list):\n","            if len(result) > 0 and isinstance(result[0], dict):\n","                return result[0].get(\"label\", default), result[0].get(\"score\", 1.0)\n","            return result[0], 1.0\n","\n","        if isinstance(result, dict):\n","            return result.get(\"label\", default), result.get(\"score\", 1.0)\n","\n","        return result, 1.0\n","    except:\n","        return default, 1.0\n","\n","\n","def normalize_sentiment(s):\n","    s = str(s).strip().lower()\n","\n","    if s in [\"negative\", \"label_0\", \"0\", \"neg\"]:\n","        return \"negative\"\n","\n","    if s in [\"positive\", \"label_2\", \"2\", \"pos\"]:\n","        return \"positive\"\n","\n","    return \"neutral\"\n","\n","\n","def normalize_intent(intent):\n","    intent = str(intent).strip().lower()\n","\n","    mapping = {\n","        \"slow internet\": \"slow_internet\",\n","        \"slow-internet\": \"slow_internet\",\n","        \"internet slow\": \"slow_internet\",\n","        \"weak internet\": \"slow_internet\",\n","\n","        \"no signal\": \"no_signal\",\n","        \"no-signal\": \"no_signal\",\n","        \"weak signal\": \"no_signal\",\n","\n","        \"network complaint\": \"network_complaint\",\n","        \"network problem\": \"network_complaint\",\n","        \"network issue\": \"network_complaint\",\n","\n","        \"network status\": \"network_status\",\n","        \"network-status\": \"network_status\",\n","\n","        \"hi\": \"greeting\",\n","        \"hello\": \"greeting\",\n","        \"hey\": \"greeting\",\n","\n","        \"bye\": \"goodbye\",\n","        \"goodbye\": \"goodbye\"\n","    }\n","\n","    return mapping.get(intent, intent)\n","\n","\n","def is_network_intent(intent):\n","    intent = normalize_intent(intent)\n","\n","    network_intents = [\n","        \"slow_internet\",\n","        \"no_signal\",\n","        \"network_status\",\n","        \"network_complaint\",\n","        \"complaint\"\n","    ]\n","\n","    return intent in network_intents\n","\n","\n","def map_intent_to_issue_type(intent, sentiment=None):\n","    intent = normalize_intent(intent)\n","\n","    if intent == \"slow_internet\":\n","        return \"high_latency\"\n","\n","    if intent == \"no_signal\":\n","        return \"weak_signal\"\n","\n","    if intent == \"network_status\":\n","        return \"service_degradation\"\n","\n","    if intent in [\"network_complaint\", \"complaint\"]:\n","        return \"unstable_connection\"\n","\n","    return \"prediction_alert\"\n","\n","\n","# =========================\n","# Load Notifications\n","# =========================\n","def load_notifications():\n","    def read_csv_safe(path):\n","        try:\n","            return pd.read_csv(path, encoding=\"utf-8-sig\")\n","        except Exception as e:\n","            print(f\"❌ CSV load error: {path}\")\n","            print(e)\n","            return pd.DataFrame()\n","\n","    internal_ar = read_csv_safe(f\"{NOTI_PATH}/ internal_notifications.csv\")  # مهم: في مسافة قبل الاسم\n","    internal_en = read_csv_safe(f\"{NOTI_PATH}/internal_notifications_en.csv\")\n","    external_ar = read_csv_safe(f\"{NOTI_PATH}/external_notifications.csv\")\n","    external_en = read_csv_safe(f\"{NOTI_PATH}/external_notifications_en.csv\")\n","\n","    print(\"✅ Notifications loaded\")\n","    print(\"INTERNAL_AR:\", internal_ar.shape)\n","    print(\"INTERNAL_EN:\", internal_en.shape)\n","    print(\"EXTERNAL_AR:\", external_ar.shape)\n","    print(\"EXTERNAL_EN:\", external_en.shape)\n","\n","    return internal_ar, internal_en, external_ar, external_en\n","\n","\n","INTERNAL_AR, INTERNAL_EN, EXTERNAL_AR, EXTERNAL_EN = load_notifications()\n","\n","\n","# =========================\n","# Safe Models\n","# =========================\n","def predict_intent_safe(user_message, lang):\n","    try:\n","        raw = predict_intent(user_message, lang)\n","        intent, confidence = normalize_model_output(raw, default=\"unknown\")\n","        return normalize_intent(intent), confidence\n","    except:\n","        text = str(user_message).lower()\n","\n","        if any(w in text for w in [\"هاي\", \"هلا\", \"مرحبا\", \"hello\", \"hi\", \"كيفك\", \"كيفو\"]):\n","            return \"greeting\", 0.8\n","\n","        if any(w in text for w in [\"بطيء\", \"ضعيف\", \"ضعيفة\", \"slow\", \"زفت\", \"خرا\", \"تقطيع\", \"سرعة\"]):\n","            return \"slow_internet\", 0.8\n","\n","        if any(w in text for w in [\"اشارة\", \"إشارة\", \"signal\", \"فاصل\"]):\n","            return \"no_signal\", 0.8\n","\n","        return \"unknown\", 0.5\n","\n","\n","def predict_sentiment_safe(user_message, lang):\n","    try:\n","        raw = predict_sentiment(user_message, lang)\n","        label, score = normalize_model_output(raw)\n","        return normalize_sentiment(label), score\n","    except:\n","        text = str(user_message).lower()\n","\n","        negative_words = [\n","            \"خرا\", \"زفت\", \"سيء\", \"بطيء\", \"ضعيف\", \"ضعيفة\", \"تخزي\", \"مشكلة\",\n","            \"bad\", \"slow\", \"angry\", \"problem\", \"terrible\", \"poor\", \"not working\"\n","        ]\n","\n","        positive_words = [\n","            \"ممتاز\", \"تمام\", \"شكرا\", \"يسلمو\",\n","            \"good\", \"great\", \"thanks\", \"excellent\"\n","        ]\n","\n","        if any(w in text for w in negative_words):\n","            return \"negative\", 0.9\n","\n","        if any(w in text for w in positive_words):\n","            return \"positive\", 0.8\n","\n","        return \"neutral\", 0.5\n","\n","\n","# =========================\n","# Dynamic Metrics\n","# =========================\n","def update_dynamic_metrics(user_id, region, intent, issue_type=\"normal\", metrics=None):\n","    metrics = metrics or {}\n","    intent = normalize_intent(intent)\n","\n","    current_is_network = is_network_intent(intent) and issue_type != \"normal\"\n","\n","    if not current_is_network:\n","        metrics[\"user_id\"] = user_id\n","        metrics[\"region\"] = region\n","        metrics[\"repeat_count\"] = 0\n","        metrics[\"area_issue_count\"] = 0\n","        metrics[\"current_is_network\"] = False\n","        return metrics\n","\n","    try:\n","        logs = pd.read_csv(CHAT_LOG_PATH, encoding=\"utf-8-sig\")\n","    except:\n","        logs = pd.DataFrame()\n","\n","    if logs.empty:\n","        repeat = 1\n","        area = 1\n","    else:\n","        required_cols = [\"user_id\", \"region\", \"intent\", \"issue_type\", \"network_problem\"]\n","\n","        for col in required_cols:\n","            if col not in logs.columns:\n","                logs[col] = None\n","\n","        logs[\"intent\"] = logs[\"intent\"].astype(str).apply(normalize_intent)\n","        logs[\"issue_type\"] = logs[\"issue_type\"].astype(str)\n","        logs[\"network_problem\"] = logs[\"network_problem\"].astype(str).str.lower()\n","\n","        network_logs = logs[\n","            (logs[\"intent\"].apply(is_network_intent)) &\n","            (logs[\"issue_type\"] != \"normal\") &\n","            (logs[\"network_problem\"].isin([\"true\", \"1\", \"yes\"]))\n","        ]\n","\n","        user_logs = network_logs[\n","            network_logs[\"user_id\"].astype(str) == str(user_id)\n","        ]\n","\n","        area_logs = network_logs[\n","            network_logs[\"region\"].astype(str) == str(region)\n","        ]\n","\n","        repeat = len(user_logs) + 1\n","        area = len(area_logs) + 1\n","\n","    metrics[\"user_id\"] = user_id\n","    metrics[\"region\"] = region\n","    metrics[\"repeat_count\"] = repeat\n","    metrics[\"area_issue_count\"] = area\n","    metrics[\"current_is_network\"] = True\n","\n","    return metrics\n","\n","\n","# =========================\n","# Prediction\n","# =========================\n","def safe_prediction(metrics, intent=None, sentiment=None):\n","    if not metrics.get(\"current_is_network\", False):\n","        return 0\n","\n","    if is_network_intent(intent):\n","        return 1\n","\n","    return 0\n","\n","\n","# =========================\n","# Notification CSV Picker\n","# =========================\n","def get_notification_message(issue_type, severity=\"medium\"):\n","    def filter_df(df):\n","        if df.empty or \"issue_type\" not in df.columns:\n","            return pd.DataFrame()\n","\n","        temp = df[df[\"issue_type\"].astype(str) == str(issue_type)]\n","\n","        if not temp.empty and \"severity\" in temp.columns:\n","            sev_temp = temp[temp[\"severity\"].astype(str) == str(severity)]\n","            if not sev_temp.empty:\n","                return sev_temp\n","\n","        return temp\n","\n","    def safe_get(df, possible_cols):\n","        if df.empty:\n","            return None\n","\n","        for col in possible_cols:\n","            if col in df.columns:\n","                value = df.iloc[0].get(col)\n","                if not pd.isna(value):\n","                    return value\n","\n","        return None\n","\n","    internal_ar = filter_df(INTERNAL_AR)\n","    internal_en = filter_df(INTERNAL_EN)\n","    external_ar = filter_df(EXTERNAL_AR)\n","    external_en = filter_df(EXTERNAL_EN)\n","\n","    return {\n","        \"internal_message_ar\": safe_get(internal_ar, [\"employee_notification_ar\", \"internal_message_ar\"]),\n","        \"internal_message_en\": safe_get(internal_en, [\"employee_notification_en\", \"internal_message_en\"]),\n","        \"external_message_ar\": safe_get(external_ar, [\"customer_notification_ar\", \"external_message_ar\"]),\n","        \"external_message_en\": safe_get(external_en, [\"customer_notification_en\", \"external_message_en\"]),\n","        \"customer_message_ar\": safe_get(internal_ar, [\"customer_notification_ar\"]),\n","        \"customer_message_en\": safe_get(internal_ar, [\"customer_notification_en\"]),\n","        \"suggested_action\": safe_get(internal_ar, [\"suggested_action\"]),\n","        \"priority\": safe_get(internal_ar, [\"priority\"]),\n","        \"escalate_after_attempts\": safe_int(safe_get(internal_ar, [\"escalate_after_attempts\"]), default=3),\n","        \"show_to_customer\": safe_int(safe_get(internal_ar, [\"show_to_customer\"]), default=0),\n","    }\n","\n","\n","# =========================\n","# Notification Engine\n","# =========================\n","def notification_engine(prediction, sentiment, metrics=None, intent=None):\n","    metrics = metrics or {}\n","\n","    repeat = safe_int(metrics.get(\"repeat_count\"))\n","    area = safe_int(metrics.get(\"area_issue_count\"))\n","\n","    if prediction == 0 or not metrics.get(\"current_is_network\", False):\n","        return {\n","            \"issue_type\": \"normal\",\n","            \"network_problem\": False,\n","            \"notification_type\": \"none\",\n","            \"display_channel\": \"none\",\n","            \"escalation\": False,\n","            \"reason\": None,\n","            \"repeat_count\": 0,\n","            \"area_issue_count\": 0,\n","            \"external_message_ar\": None,\n","            \"external_message_en\": None,\n","            \"internal_message_ar\": None,\n","            \"internal_message_en\": None,\n","            \"priority\": None,\n","            \"suggested_action\": None,\n","            \"show_to_customer\": 0\n","        }\n","\n","    issue_type = map_intent_to_issue_type(intent, sentiment)\n","    severity = \"medium\"\n","\n","    noti = get_notification_message(issue_type, severity)\n","\n","    escalate_after = safe_int(noti.get(\"escalate_after_attempts\"), default=3)\n","    show_to_customer = safe_int(noti.get(\"show_to_customer\"), default=0)\n","\n","    escalation = False\n","    notification_type = \"internal_noti\"\n","    display_channel = \"employee_dashboard\"\n","    reason = None\n","\n","    if area >= 5 and show_to_customer == 1:\n","        escalation = True\n","        notification_type = \"external_noti\"\n","        display_channel = \"customer_app\"\n","        reason = \"Area-wide issue\"\n","\n","    elif repeat >= escalate_after:\n","        escalation = True\n","        notification_type = \"internal_noti\"\n","        display_channel = \"employee_dashboard\"\n","        reason = \"Repeated user issue\"\n","\n","    internal_ar = noti.get(\"internal_message_ar\")\n","    internal_en = noti.get(\"internal_message_en\")\n","\n","    # ترجمة تلقائية إذا ما في رسالة داخلية إنجليزي\n","    if internal_en is None and internal_ar is not None:\n","        try:\n","            from deep_translator import GoogleTranslator\n","            internal_en = GoogleTranslator(source=\"ar\", target=\"en\").translate(internal_ar)\n","        except:\n","            internal_en = internal_ar\n","\n","    external_ar = noti.get(\"external_message_ar\") or noti.get(\"customer_message_ar\")\n","    external_en = noti.get(\"external_message_en\") or noti.get(\"customer_message_en\")\n","\n","    return {\n","        \"issue_type\": issue_type,\n","        \"network_problem\": True,\n","        \"notification_type\": notification_type,\n","        \"display_channel\": display_channel,\n","        \"escalation\": escalation,\n","        \"reason\": reason,\n","        \"repeat_count\": repeat,\n","        \"area_issue_count\": area,\n","        \"external_message_ar\": external_ar,\n","        \"external_message_en\": external_en,\n","        \"internal_message_ar\": internal_ar,\n","        \"internal_message_en\": internal_en,\n","        \"priority\": noti.get(\"priority\"),\n","        \"suggested_action\": noti.get(\"suggested_action\"),\n","        \"show_to_customer\": show_to_customer\n","    }\n","# =========================\n","# Responses\n","# =========================\n","def get_intent_response(lang, intent):\n","    intent = normalize_intent(intent)\n","\n","    responses = {\n","        \"ar\": {\n","            \"greeting\": (\"هلا وغلا 👋 كيف فيني أساعدك؟\", \"شو حاب تعرف؟\"),\n","            \"slow_internet\": (\"واضح النت عندك بطيء.\", \"بدك نحلها مع بعض؟\"),\n","            \"no_signal\": (\"فهمت عليك، واضح في مشكلة بالإشارة.\", \"وين موقعك تقريباً؟\"),\n","            \"network_status\": (\"خليني أشيك حالة الشبكة عندك.\", \"أي منطقة موجود فيها؟\"),\n","            \"network_complaint\": (\"آسفين على الإزعاج، رح نتابع المشكلة فوراً.\", \"صار معك هالشي أكثر من مرة؟\"),\n","            \"complaint\": (\"آسفين على الإزعاج، رح نتابع المشكلة فوراً.\", \"صار معك هالشي أكثر من مرة؟\"),\n","            \"goodbye\": (\"مع السلامة 👋\", \"أي وقت تحتاجنا إحنا موجودين.\")\n","        },\n","        \"en\": {\n","            \"greeting\": (\"Hello 👋 How can I help you?\", \"What would you like to know?\"),\n","            \"slow_internet\": (\"It looks like your internet is slow.\", \"Do you want me to check the issue?\"),\n","            \"no_signal\": (\"I understand. There may be a signal problem.\", \"What is your approximate location?\"),\n","            \"network_status\": (\"Let me check the network status for you.\", \"Which area are you in?\"),\n","            \"network_complaint\": (\"Sorry for the inconvenience. We will follow up on the issue.\", \"Has this happened more than once?\"),\n","            \"complaint\": (\"Sorry for the inconvenience. We will follow up on the issue.\", \"Has this happened more than once?\"),\n","            \"goodbye\": (\"Goodbye 👋\", \"We are here whenever you need help.\")\n","        }\n","    }\n","\n","    lang = \"ar\" if lang == \"ar\" else \"en\"\n","\n","    return responses[lang].get(\n","        intent,\n","        (\n","            \"ممكن توضح أكثر؟\" if lang == \"ar\" else \"Could you clarify more?\",\n","            \"احكيلي تفاصيل أكثر\" if lang == \"ar\" else \"Please provide more details.\"\n","        )\n","    )\n","\n","\n","# =========================\n","# Logging\n","# =========================\n","def log_chat(user_message, result):\n","    os.makedirs(os.path.dirname(CHAT_LOG_PATH), exist_ok=True)\n","\n","    row = {\n","        \"timestamp\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"),\n","        \"user_id\": result.get(\"user_id\"),\n","        \"region\": result.get(\"region\"),\n","        \"message\": user_message,\n","        \"language\": result.get(\"language\"),\n","        \"intent\": result.get(\"intent\"),\n","        \"intent_confidence\": result.get(\"intent_confidence\"),\n","        \"sentiment\": result.get(\"sentiment\"),\n","        \"sentiment_score\": result.get(\"sentiment_score\"),\n","        \"prediction\": result.get(\"prediction\"),\n","        \"issue_type\": result.get(\"issue_type\"),\n","        \"network_problem\": result.get(\"network_problem\"),\n","        \"notification_type\": result.get(\"notification_type\"),\n","        \"display_channel\": result.get(\"display_channel\"),\n","        \"escalation\": result.get(\"escalation\"),\n","        \"reason\": result.get(\"reason\"),\n","        \"repeat_count\": result.get(\"repeat_count\"),\n","        \"area_issue_count\": result.get(\"area_issue_count\"),\n","    }\n","\n","    try:\n","        old = pd.read_csv(CHAT_LOG_PATH, encoding=\"utf-8-